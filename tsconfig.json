{
    "compilerOptions": {
        "outDir": "./dist/",
        "noImplicitAny": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "esnext",
        "jsx": "react-jsx",
        "allowJs": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "isolatedModules": true
    },
    "ts-node": {
        "transpileOnly": true,
        "compilerOptions": {
            "module": "CommonJS",
            "moduleResolution": "node"
        }
    },
    "include": [
        "src/**/*",
        "webpack.config.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}